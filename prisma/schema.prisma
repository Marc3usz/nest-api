generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        Int        @id @default(autoincrement())
  name      String
  price     Decimal    @db.Decimal(10, 2)
  cartItems CartItem[]
}

model CartItem {
  id        Int     @id @default(autoincrement())
  productId Int     @unique
  quantity  Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}
