generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id    Int     @id @default(autoincrement())
  name  String
  price Decimal @db.Decimal(10, 2)
}

model Cart {
  id  Int    @id @default(autoincrement())
  key String @unique
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}
